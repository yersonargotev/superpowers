#!/usr/bin/env bash
# Wrapper that resolves COPILOT_PLUGIN_ROOT when the environment variable
# is not set by the host, then delegates to the shared session-start hook.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

export COPILOT_PLUGIN_ROOT="${COPILOT_PLUGIN_ROOT:-$PLUGIN_ROOT}"

exec "${PLUGIN_ROOT}/hooks/session-start"
